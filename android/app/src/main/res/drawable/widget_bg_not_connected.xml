<?xml version="1.0" encoding="utf-8"?>
<!-- ✅ script item 11: not connected — উষ্ণ, আমন্ত্রণমূলক পিংক-পার্পল gradient,
     paused-এর মতো বিষণ্ণ না, বরং আশাব্যঞ্জক অনুভূতি — "এখনো কারো সাথে যুক্ত
     হওনি, চলো শুরু করি"। -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFFF9FC7"
                android:centerColor="#FFE884B8"
                android:endColor="#FFB185D9" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#33FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="1.3dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>

</layer-list>
