<?xml version="1.0" encoding="utf-8"?>
<!-- ✅ script item 10: paused relationship — নরম, বিষণ্ণ কিন্তু নিষ্ঠুর নয় এমন
     একটা muted violet-gray gradient — সম্পর্কটা "থেমে আছে" কিন্তু "শেষ হয়ে
     যায়নি" এই অনুভূতিটা রাখা হয়েছে; reconnect করলেই আবার জীবন্ত হবে। -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FF6B6478"
                android:centerColor="#FF544D66"
                android:endColor="#FF3A3450" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:centerX="0.5"
                android:centerY="0.35"
                android:startColor="#22FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="1.3dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>

</layer-list>
