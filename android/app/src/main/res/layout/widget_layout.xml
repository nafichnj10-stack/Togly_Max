<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/layout_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_status_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_status_line1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Meeting"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:shadowColor="#EE000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/tv_status_line2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="43 days"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold"
            android:shadowColor="#EE000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/tv_status_line3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFF9AD1"
            android:textSize="9sp"
            android:shadowColor="#EE000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4" />

    </LinearLayout>

    <!-- ✅ Task 5 (v2): dedicated card-style Next Meeting Countdown, replacing
         the old plain-text 3-line header for normal/travel_upcoming/together
         states. layout_status (above) is still used for love_sent/sleep/
         birthday etc. The two are mutually exclusive - only one visible at a time. -->
    <LinearLayout
        android:id="@+id/card_next_meeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_next_meeting_card"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_nm_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_nm_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Next meeting"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:shadowColor="#EE000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_nm_datetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Jul 17, 2026 · 12:00 PM"
            android:textColor="#FFF0F0F0"
            android:textSize="9sp"
            android:singleLine="true"
            android:shadowColor="#EE000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_nm_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="📍 Hanover, Germany"
            android:textColor="#FFF0F0F0"
            android:textSize="9sp"
            android:singleLine="true"
            android:shadowColor="#EE000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="26dp">
                <TextView
                    android:id="@+id/tv_nm_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:shadowColor="#EE000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3" />
                <TextView
                    android:id="@+id/tv_nm_days_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DAYS"
                    android:textColor="#FFE0C7DB"
                    android:textSize="7sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="#55FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="26dp">
                <TextView
                    android:id="@+id/tv_nm_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:shadowColor="#EE000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3" />
                <TextView
                    android:id="@+id/tv_nm_hours_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HRS"
                    android:textColor="#FFE0C7DB"
                    android:textSize="7sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="#55FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="26dp">
                <TextView
                    android:id="@+id/tv_nm_minutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="35"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:shadowColor="#EE000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3" />
                <TextView
                    android:id="@+id/tv_nm_minutes_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIN"
                    android:textColor="#FFE0C7DB"
                    android:textSize="7sp" />
            </LinearLayout>

            <View
                android:id="@+id/divider_nm_seconds"
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="#55FFFFFF" />

            <LinearLayout
                android:id="@+id/group_nm_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:minWidth="26dp">
                <TextView
                    android:id="@+id/tv_nm_seconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="42"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:shadowColor="#EE000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="3" />
                <TextView
                    android:id="@+id/tv_nm_seconds_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEC"
                    android:textColor="#FFE0C7DB"
                    android:textSize="7sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_last_gps_update"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/layout_status"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="2dp"
        android:text="📡 Updated just now"
        android:textColor="#FFFFE3F1"
        android:textSize="8sp"
        android:visibility="gone"
        android:shadowColor="#DD000000"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="3" />

    <LinearLayout
        android:id="@+id/btn_send_love"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_send_love"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/tv_send_love_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️ Send Love"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <ImageView
        android:id="@+id/img_profile_bar"
        android:layout_width="218dp"
        android:layout_height="92dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="35dp"
        android:scaleType="fitXY" />

    <LinearLayout
        android:id="@+id/card_name_left"
        android:layout_width="76dp"
        android:layout_height="29dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="7dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_name_card"
        android:paddingStart="3dp"
        android:paddingEnd="3dp">

        <TextView
            android:id="@+id/tv_name_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐾 Bam"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_flag_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇩🇪 Germany"
            android:textColor="#FFF0F7"
            android:textSize="8sp"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_name_right"
        android:layout_width="76dp"
        android:layout_height="29dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="7dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_name_card"
        android:paddingStart="3dp"
        android:paddingEnd="3dp">

        <TextView
            android:id="@+id/tv_name_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐾 Mimi"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/tv_flag_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇹🇭 Thailand"
            android:textColor="#FFF0F7"
            android:textSize="8sp"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/card_time_diff"
        android:layout_width="84dp"
        android:layout_height="20dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="9dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_time_card">

        <TextView
            android:id="@+id/tv_time_diff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🕐 1h diff"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:shadowColor="#AA8B0050"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3" />

    </LinearLayout>

</RelativeLayout>
